---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingCta from '../components/BookingCta.astro';
import CharterCard from '../components/CharterCard.astro';
import ReviewCard from '../components/ReviewCard.astro';
import FaqAccordion from '../components/FaqAccordion.astro';
import Marquee from '../components/Marquee.astro';
import { business } from '../data/site';
import { services } from '../data/services';
import { homeReviews } from '../data/reviews';
import * as homeImages from '../data/homeImages';
import { serviceAreas } from '../data/serviceAreas';

// Full homepage build (Phase 2 redesign) — real content from
// https://www.fishcoolrunnings.com/, but a deliberately different, more
// modern structure: bento-style charter grid, marquee strips, a scroll-snap
// review carousel, a full-bleed split captain section, and a clean photo
// grid instead of the reference's plain stacked layout.
//
// Milestone B pages (About, Service Areas, Gallery, Reviews) now exist —
// cross-links that were previously stripped/omitted are restored below.

// "5★ on 69 Google Reviews" already leads the floating stat card right above
// this strip — left out here so it isn't repeated back to back.
const trustItems = [
  'Bass2Billfish with Peter Miller',
  'Tournament Placements & Wins',
  'Fort Lauderdale Sportfishing Community',
];

---

<BaseLayout
  title="Fort Lauderdale Fishing Charters | Cool Runnings Sportfishing"
  description="Fort Lauderdale fishing charters for sailfish, mahi, wahoo, kingfish, snapper, tarpon & snook. Half-day to full-day fishing trips. Call now: 954-588-0578"
>
  <!-- Hero -->
  <section class="relative flex min-h-[92vh] items-end overflow-hidden bg-navy-950 text-white">
    <img
      src={homeImages.hero.src}
      alt={homeImages.hero.alt}
      width="1600"
      height="1000"
      loading="eager"
      class="absolute inset-0 h-full w-full origin-center object-cover motion-safe:animate-kenburns"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/60 to-navy-950/20"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-navy-950/70 via-transparent to-transparent"></div>

    <div class="relative mx-auto w-full max-w-7xl px-4 pb-28 pt-40 sm:px-6 sm:pb-32 lg:px-8">
      <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 font-body text-xs font-bold uppercase tracking-widest text-teal-300 backdrop-blur">
        <svg class="h-3 w-3" viewBox="0 0 8 8" fill="currentColor" aria-hidden="true"><circle cx="4" cy="4" r="4" /></svg>
        Cox Landing, Fort Lauderdale
      </span>
      <h1 class="mt-5 max-w-3xl font-display text-5xl font-extrabold leading-[1.05] tracking-tight sm:text-6xl lg:text-7xl">
        Chase the <span class="text-teal-400">Gulf Stream</span> Out of Fort Lauderdale
      </h1>
      <p class="mt-6 max-w-lg font-body text-base text-white/85 sm:text-lg">
        Captain Jason Robinson runs the Cool Runnings 32 ft Contender out of Cox Landing —
        inshore, offshore, and bottom fishing, 10+ years on these waters, 5 stars on 69 Google
        reviews.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={business.bookingUrl}
          class="inline-flex items-center justify-center rounded-full bg-ocean-600 px-8 py-4 font-body text-base font-bold text-white shadow-lg shadow-ocean-600/30 transition-colors hover:bg-ocean-500"
        >
          Book A Charter
        </a>
        <a
          href={business.phone.href}
          class="inline-flex items-center justify-center rounded-full border border-white/30 px-8 py-4 font-body text-base font-bold text-white backdrop-blur transition-colors hover:bg-white/10"
        >
          Call {business.phone.display}
        </a>
      </div>
    </div>
  </section>

  <!-- Floating stat card — overlaps the hero/next-section boundary. Sits
       outside the hero <section> (which has overflow-hidden for the Ken
       Burns image) so the negative margin isn't clipped.

       This outer band is full-bleed bg-navy-950 (matching the hero's own
       bottom color and the "Recognized By" section right after it) so the
       margins on either side of the centered card show continuous navy
       instead of exposing a gap of bare page background — that gap was the
       visible "hole" on desktop widths where the card's max-w-6xl left
       empty space beside it uncovered. -->
  <div class="relative z-10 -mt-12 bg-navy-950 pb-14 sm:-mt-14 sm:pb-16">
    <div class="mx-auto w-full max-w-6xl px-4 sm:px-6 lg:px-8">
      <dl class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl bg-navy-950/10 shadow-2xl ring-1 ring-black/5 lg:grid-cols-4">
        {
          [
            ['5★ · 69', 'Google Reviews'],
            ['10+ Years', 'On These Waters'],
            ['30+', 'Species Targeted'],
            ['4-6 Guests', 'Max Per Trip'],
          ].map(([value, label]) => (
            <div class="bg-white px-5 py-6 text-center">
              <dt class="font-display text-xl font-extrabold text-navy-950 sm:text-2xl">{value}</dt>
              <dd class="mt-1 font-body text-xs font-bold uppercase tracking-wide text-navy-950/50 sm:text-sm">
                {label}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </div>

  <!-- Recognized By — only 3 real trust signals, so a static wrapped row
       (not a scrolling marquee) avoids the sparse, mostly-empty look a
       ticker gets when it doesn't have enough content to stay busy. -->
  <section class="bg-navy-950 pt-2 pb-14 sm:pb-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <p class="text-center font-body text-xs font-bold uppercase tracking-widest text-teal-400/70">
        Recognized By
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        {
          trustItems.map((item) => (
            <span class="flex items-center gap-2.5 rounded-full border border-white/10 bg-white/5 px-5 py-2.5 font-body text-xs font-bold uppercase tracking-wide text-white/80 sm:text-sm">
              <svg class="h-4 w-4 flex-shrink-0 text-teal-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10 1.5l2.6 5.5 6 .7-4.4 4.1 1.2 6-5.4-3-5.4 3 1.2-6-4.4-4.1 6-.7L10 1.5Z" />
              </svg>
              {item}
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Our Charters — bento grid -->
  <section class="py-section-sm sm:py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <span class="font-body text-sm font-bold uppercase tracking-wide text-teal-500">
            Three Ways to Fish
          </span>
          <h2 class="mt-2 font-display text-3xl font-extrabold text-navy-950 sm:text-4xl">
            Pick Your Trip
          </h2>
        </div>
        <p class="max-w-sm font-body text-sm text-navy-950/60 sm:text-right">
          Every charter runs on the same 32 ft Contender with Captain Jason at the wheel.
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-5 sm:grid-cols-2">
        {
          services.map((service, i) => (
            <CharterCard
              href={service.href}
              tag={service.tag}
              title={service.title}
              description={service.cardDescription}
              image={service.heroImage}
              imageAlt={service.heroImageAlt}
              featured={i === 0}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Meet Captain Jason — full-bleed split -->
  <section class="relative overflow-hidden bg-sand-100">
    <div class="mx-auto grid max-w-7xl grid-cols-1 lg:grid-cols-2">
      <div class="relative min-h-[22rem] lg:min-h-[32rem]">
        <img
          src={homeImages.captain.src}
          alt={homeImages.captain.alt}
          width="800"
          height="960"
          loading="lazy"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute bottom-4 left-4 right-4 flex flex-wrap gap-2 sm:bottom-6 sm:left-6 sm:right-auto">
          {
            ['Tournament-Tested', 'TV-Featured', '10+ Years Local'].map((badge) => (
              <span class="rounded-full bg-white/90 px-3 py-1.5 font-body text-xs font-extrabold uppercase tracking-wide text-navy-950 backdrop-blur">
                {badge}
              </span>
            ))
          }
        </div>
      </div>
      <div class="flex flex-col justify-center px-4 py-16 sm:px-10 sm:py-20 lg:px-16">
        <span class="font-body text-sm font-bold uppercase tracking-wide text-teal-500">
          The Captain
        </span>
        <h2 class="mt-2 font-display text-3xl font-extrabold text-navy-950 sm:text-4xl">
          Meet Captain Jason
        </h2>
        <p class="mt-6 border-l-4 border-teal-500 pl-5 font-display text-lg font-bold italic leading-snug text-navy-950/90 sm:text-xl">
          "Just as comfortable putting a first-timer on their first sailfish as he is coaching a
          veteran angler."
        </p>
        <p class="mt-6 font-body text-base text-navy-950/70">
          South Florida native with over a decade running Cool Runnings out of the Fort
          Lauderdale area. Tournament-tested, TV-featured — featured on Bass2Billfish with Peter
          Miller — and fishing everything from tarpon in the bay to billfish on the edge.
        </p>
        <p class="mt-4 font-body text-base text-navy-950/70">
          The four-guest max keeps every angler on a rod when the bite hits.
        </p>
        <a href="/about/" class="mt-6 inline-flex w-fit items-center gap-1 font-body text-sm font-extrabold text-ocean-600">
          Read the Captain's Story
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- As Seen In / Sponsored By -->
  <section class="border-y border-navy-950/5 bg-white py-10">
    <p class="text-center font-body text-xs font-bold uppercase tracking-widest text-navy-950/40">
      As Seen In · Sponsored By
    </p>
    <div class="mt-6">
      <Marquee speed="slow">
        {
          [...homeImages.press, ...homeImages.sponsors].map((item) => (
            <img
              src={item.src}
              alt={item.alt}
              width="160"
              height="60"
              loading="lazy"
              class="h-9 w-auto flex-shrink-0 object-contain grayscale transition-all hover:grayscale-0 sm:h-11"
            />
          ))
        }
      </Marquee>
    </div>
  </section>

  <!-- Where We Run -->
  <section class="py-section-sm sm:py-section">
    <div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
      <div>
        <span class="font-body text-sm font-bold uppercase tracking-wide text-teal-500">
          Where We Run
        </span>
        <h2 class="mt-2 font-display text-3xl font-extrabold text-navy-950 sm:text-4xl">
          From the Dock to Your Favorite Water
        </h2>
        <p class="mt-4 max-w-md font-body text-base text-navy-950/70">
          We run out of Cox Landing in Fort Lauderdale. We fish from Boca down to Miami, with
          most pickups inside a 20-minute drive of the home dock.
        </p>
      </div>
      <div class="flex flex-col items-start gap-4 lg:items-end">
        <div class="flex flex-wrap gap-3 lg:justify-end">
          {
            serviceAreas.map((area) => (
              <a
                href={area.href}
                class="flex items-center gap-2 rounded-full border border-navy-950/10 bg-white px-4 py-2.5 font-body text-sm font-bold text-navy-950/80 shadow-sm transition-colors hover:border-ocean-600 hover:text-ocean-600"
              >
                <svg class="h-3.5 w-3.5 text-teal-500" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                  <path d="M8 0C4.7 0 2 2.7 2 6c0 4.5 6 10 6 10s6-5.5 6-10c0-3.3-2.7-6-6-6Zm0 8.5A2.5 2.5 0 1 1 8 3.5a2.5 2.5 0 0 1 0 5Z" />
                </svg>
                {area.name}
              </a>
            ))
          }
        </div>
        <a href="/service-areas/" class="inline-flex items-center gap-1 font-body text-sm font-extrabold text-ocean-600">
          See All Service Areas
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Reviews — scroll-snap carousel -->
  <section class="bg-navy-950 py-section-sm text-white sm:py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <span class="font-body text-sm font-bold uppercase tracking-wide text-teal-400">
            The Word From the Dock
          </span>
          <h2 class="mt-2 font-display text-3xl font-extrabold sm:text-4xl">
            What 69 Anglers Have Said
          </h2>
          <p class="mt-2 font-body text-sm text-white/60">5.0 average · 69 Google reviews</p>
        </div>
        <div class="hidden gap-2 sm:flex">
          <button
            type="button"
            id="review-prev"
            aria-label="Previous reviews"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white transition-colors hover:bg-white/10"
          >
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M10 3 5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <button
            type="button"
            id="review-next"
            aria-label="Next reviews"
            class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white transition-colors hover:bg-white/10"
          >
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>
      </div>

      <div id="review-track" class="snap-x-mandatory mt-10 flex gap-5 overflow-x-auto pb-4">
        {
          homeReviews.map((review) => (
            <ReviewCard name={review.name} tripType={review.tripType} quote={review.quote} />
          ))
        }
      </div>
      <div class="mt-8 text-center">
        <a href="/reviews/" class="inline-flex items-center gap-1 font-body text-sm font-extrabold text-teal-400">
          Read All 69 Fishing Charter Reviews
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Gallery preview -->
  <section class="py-section-sm sm:py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <span class="font-body text-sm font-bold uppercase tracking-wide text-teal-500">
          On the Water
        </span>
        <h2 class="mt-2 font-display text-3xl font-extrabold text-navy-950 sm:text-4xl">
          Catch Of The Day
        </h2>
      </div>
      <div class="mt-10 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6">
        {
          homeImages.gallery.map((photo) => (
            <a href="/gallery/" class="group block overflow-hidden rounded-xl">
              <img
                src={photo.src}
                alt={photo.alt}
                width="400"
                height="400"
                loading="lazy"
                class="aspect-square w-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
            </a>
          ))
        }
      </div>
      <div class="mt-8 text-center">
        <a href="/gallery/" class="inline-flex items-center gap-1 font-body text-sm font-extrabold text-ocean-600">
          Full Photo Gallery
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-sand-100 py-section-sm sm:py-section">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-[minmax(0,1fr)_minmax(0,2fr)] lg:px-8">
      <div>
        <span class="font-body text-sm font-bold uppercase tracking-wide text-teal-500">
          Know Before You Go
        </span>
        <h2 class="mt-2 font-display text-3xl font-extrabold text-navy-950">
          Common Questions
        </h2>
        <div class="mt-6 rounded-2xl bg-navy-950 p-6 text-white">
          <p class="font-body text-sm text-white/70">Still have a question?</p>
          <a
            href={business.phone.href}
            class="mt-2 block font-display text-xl font-extrabold text-teal-400"
          >
            {business.phone.display}
          </a>
          <p class="mt-1 font-body text-xs text-white/50">{business.hours.display}</p>
        </div>
      </div>
      <div class="rounded-2xl bg-white p-2 shadow-sm sm:p-4">
        <FaqAccordion question="How far in advance should I book?">
          Two to four weeks ahead is the safe window for weekends and peak season. Same-day
          bookings happen when we have an open slot. <a href={business.phone.href} class="font-bold text-ocean-600 hover:underline">Call {business.phone.display}</a> or
          use our <a href="/contact/" class="font-bold text-ocean-600 hover:underline">Fort Lauderdale charter booking form</a> to lock in a date.
        </FaqAccordion>
        <FaqAccordion question="What is the difference between offshore, inshore, and bottom fishing?">
          Quick version. <a href="/services/offshore-fishing/" class="font-bold text-ocean-600 hover:underline">Fort Lauderdale offshore fishing charters</a> push
          out to the Gulf Stream for sailfish, mahi, and tuna. <a href="/services/inshore-fishing/" class="font-bold text-ocean-600 hover:underline">Inshore fishing in Fort Lauderdale</a> stays
          in the Intracoastal for snook, tarpon, and redfish. <a href="/services/bottom-fishing/" class="font-bold text-ocean-600 hover:underline">Bottom fishing charters</a> drop
          on the reefs and wrecks for snapper and grouper.
        </FaqAccordion>
        <FaqAccordion question="Do I need a Florida fishing license?">
          No. Florida law covers everyone fishing on a licensed charter boat under the captain's
          saltwater license. You just show up with sun protection, soft-soled shoes, food, and a
          camera. We provide rods, reels, tackle, bait, ice, coolers, and clean and bag your catch
          at the dock.
        </FaqAccordion>
        <FaqAccordion question="Where do we meet for the trip?">
          Pickup is at Cox Landing in Fort Lauderdale. The exact dock and time get confirmed when
          you book. Most hotels along the beach strip, Las Olas, and the 17th Street Causeway are
          inside a five-minute drive. We also run trips for guests from Pompano Beach, Hollywood,
          and Dania Beach.
        </FaqAccordion>
        <FaqAccordion question="What if the weather is bad on my trip day?">
          Captain Jason makes the call based on the morning forecast and the offshore wave
          reports. If the conditions are unsafe, we reschedule with no penalty. If conditions are
          marginal but workable, we may switch from a long offshore run to a shorter reef trip or
          an inshore day. Safety first, always.
        </FaqAccordion>
      </div>
    </div>
  </section>

  <BookingCta backgroundImage={homeImages.hero.src} />
</BaseLayout>

<script>
  // Reviews carousel — desktop prev/next buttons scroll the snap track.
  // Mobile relies on native touch scroll (snap-x-mandatory handles that).
  const track = document.getElementById('review-track');
  const prevBtn = document.getElementById('review-prev');
  const nextBtn = document.getElementById('review-next');

  function scrollByCard(direction: 1 | -1) {
    if (!track) return;
    const card = track.querySelector('.snap-card') as HTMLElement | null;
    const amount = (card?.offsetWidth ?? 340) + 20;
    track.scrollBy({ left: amount * direction, behavior: 'smooth' });
  }

  prevBtn?.addEventListener('click', () => scrollByCard(-1));
  nextBtn?.addEventListener('click', () => scrollByCard(1));
</script>
