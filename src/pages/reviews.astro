---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookingCta from '../components/BookingCta.astro';
import { allReviews } from '../data/reviews';
import { business } from '../data/site';

// /reviews/ — full reviews page. Content sourced from
// https://www.fishcoolrunnings.com/reviews/ (fetched live).

const stats = [
  { value: '5.0', label: 'Average Rating' },
  { value: '69', label: 'Google Reviews' },
  { value: '10+', label: 'Years On The Water' },
];
---

<BaseLayout
  title="Cool Runnings Sportfishing Charter Reviews | 5 Star on 69 Google Reviews"
  description="Read reviews from anglers who have fished Fort Lauderdale and Miami with Captain Jason Robinson. 5-star average across 69 Google reviews."
>
  <!-- Hero -->
  <section class="relative flex min-h-[45vh] items-end overflow-hidden bg-navy-950 text-white">
    <img
      src="/images/hero-reviews.webp"
      alt="Happy clients on the Cool Runnings boat after a Fort Lauderdale fishing charter"
      width="1600"
      height="900"
      loading="eager"
      class="absolute inset-0 h-full w-full object-cover opacity-60"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/50 to-navy-950/10"></div>
    <div class="relative mx-auto w-full max-w-7xl px-4 pb-16 pt-32 sm:px-6 sm:pb-20 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-4 flex items-center gap-1.5 font-body text-xs font-bold uppercase tracking-wide text-white/60">
        <a href="/" class="hover:text-teal-400">Home</a>
        <span aria-hidden="true">/</span>
        <span class="text-white/90">Reviews</span>
      </nav>
      <span class="inline-flex w-fit items-center rounded-full bg-teal-500 px-3 py-1 font-body text-xs font-extrabold uppercase tracking-wide text-navy-950">
        What Anglers Say About the Trip
      </span>
      <h1 class="mt-4 max-w-2xl font-display text-4xl font-extrabold leading-tight sm:text-5xl">
        Reviews
      </h1>
      <p class="mt-4 max-w-xl font-body text-base text-white/85 sm:text-lg">
        Five stars across 69 Google reviews. Below is a sample of what guests have said about a
        day fishing with Captain Jason aboard the Cool Runnings 32 ft Contender.
      </p>
    </div>
  </section>

  <!-- Stat bar -->
  <section class="border-b border-navy-950/10 bg-sand-100">
    <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-center gap-2 text-teal-500" aria-hidden="true">
        {Array.from({ length: 5 }).map(() => (
          <svg viewBox="0 0 20 20" class="h-6 w-6 fill-current">
            <path d="M10 1.5l2.6 5.5 6 .7-4.4 4.1 1.2 6-5.4-3-5.4 3 1.2-6L1.4 7.7l6-.7L10 1.5Z" />
          </svg>
        ))}
      </div>
      <p class="mt-2 text-center font-body text-sm text-navy-950/60">
        5.0 out of 5 · {business.reviews.count} verified reviews on Google
      </p>
      <div class="mt-8 grid grid-cols-3 gap-6">
        {
          stats.map((stat) => (
            <div class="text-center">
              <p class="font-display text-3xl font-extrabold text-navy-950 sm:text-4xl">{stat.value}</p>
              <p class="mt-1 font-body text-xs font-bold uppercase tracking-wide text-navy-950/60">{stat.label}</p>
            </div>
          ))
        }
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a
          href="https://www.google.com/maps/search/?api=1&query=Cool+Runnings+Sportfishing+Charters+Fort+Lauderdale"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-navy-950 px-6 py-3 font-body text-sm font-bold text-white transition-colors hover:bg-navy-900"
        >
          See All Reviews on Google
        </a>
        <a
          href="https://www.google.com/maps/search/?api=1&query=Cool+Runnings+Sportfishing+Charters+Fort+Lauderdale"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full border border-navy-950/20 px-6 py-3 font-body text-sm font-bold text-navy-950 transition-colors hover:bg-white"
        >
          Write a Review
        </a>
      </div>
    </div>
  </section>

  <!-- Review grid -->
  <section class="py-section-sm sm:py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="columns-1 gap-5 sm:columns-2 lg:columns-3 [&>*]:mb-5 [&>*]:break-inside-avoid">
        {
          allReviews.map((review) => (
            <figure class="rounded-2xl bg-sand-100 p-6">
              <div class="flex gap-0.5 text-teal-500" aria-hidden="true">
                {Array.from({ length: 5 }).map(() => (
                  <svg viewBox="0 0 20 20" class="h-4 w-4 fill-current">
                    <path d="M10 1.5l2.6 5.5 6 .7-4.4 4.1 1.2 6-5.4-3-5.4 3 1.2-6L1.4 7.7l6-.7L10 1.5Z" />
                  </svg>
                ))}
              </div>
              <blockquote class="mt-3 font-body text-sm leading-relaxed text-navy-950/80">
                "{review.quote}"
              </blockquote>
              <figcaption class="mt-4 font-body text-sm">
                <span class="font-extrabold text-navy-950">{review.name}</span>
                <span class="text-navy-950/50">
                  {review.tripType ? ` · ${review.tripType} · ${review.date}` : ` · ${review.date}`}
                </span>
              </figcaption>
            </figure>
          ))
        }
      </div>
      <p class="mt-8 text-center font-body text-sm text-navy-950/50">
        The reviews above are a sample.{' '}
        <a
          href="https://www.google.com/maps/search/?api=1&query=Cool+Runnings+Sportfishing+Charters+Fort+Lauderdale"
          target="_blank"
          rel="noopener noreferrer"
          class="font-bold text-ocean-600 hover:underline"
        >
          See all {business.reviews.count} reviews on Google
        </a>.
      </p>
    </div>
  </section>

  <BookingCta
    heading="Ready to Be Our Next 5-Star Review?"
    body="Book a charter and join the list of anglers who walked off the Cool Runnings dock smiling."
  />
</BaseLayout>

<style>
  /* Multi-column masonry with 24 real reviews is well above the low-item-count
     threshold that caused the earlier gallery whitespace bug — safe to use
     columns here since there's plenty of content to balance across columns. */
</style>
