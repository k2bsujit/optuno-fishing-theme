---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BookingCta from '../../components/BookingCta.astro';
import { serviceAreas } from '../../data/serviceAreas';

// /service-areas/ hub — content sourced from
// https://www.fishcoolrunnings.com/service-areas/ (fetched live). Fort
// Lauderdale (the home dock) gets a featured banner treatment; the other 6
// areas render as a grid, each linking to its real detail page.

const [homeDockArea, ...otherAreas] = serviceAreas;
---

<BaseLayout
  title="Fishing Charter Service Areas | Fort Lauderdale to Boca Raton & Miami"
  description="Cool Runnings Sportfishing Charters serves Fort Lauderdale, Pompano Beach, Hollywood, Dania Beach, Deerfield Beach, Boca Raton, and Miami. See our home waters."
>
  <!-- Hero -->
  <section class="relative flex min-h-[50vh] items-end overflow-hidden bg-navy-950 text-white">
    <img
      src="/images/hero-areas-hub.webp"
      alt="Fort Lauderdale coastline and the Intracoastal Waterway Cool Runnings fishes year round"
      width="1600"
      height="900"
      loading="eager"
      class="absolute inset-0 h-full w-full object-cover opacity-60"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/50 to-navy-950/10"></div>
    <div class="relative mx-auto w-full max-w-7xl px-4 pb-16 pt-32 sm:px-6 sm:pb-20 lg:px-8">
      <nav aria-label="Breadcrumb" class="mb-4 flex items-center gap-1.5 font-body text-xs font-bold uppercase tracking-wide text-white/60">
        <a href="/" class="hover:text-teal-400">Home</a>
        <span aria-hidden="true">/</span>
        <span class="text-white/90">Service Areas</span>
      </nav>
      <span class="inline-flex w-fit items-center rounded-full bg-teal-500 px-3 py-1 font-body text-xs font-extrabold uppercase tracking-wide text-navy-950">
        Boca to Miami · Home Dock at 15th Street
      </span>
      <h1 class="mt-4 max-w-2xl font-display text-4xl font-extrabold leading-tight sm:text-5xl">
        Where We Fish
      </h1>
      <p class="mt-4 max-w-xl font-body text-base text-white/85 sm:text-lg">
        Fort Lauderdale is the home dock. Our reach runs from Boca Raton south through Pompano,
        Deerfield, Dania, and Hollywood, all the way to Miami on request.
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-section-sm sm:py-section">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="font-body text-base leading-relaxed text-navy-950/75">
        Cool Runnings Sportfishing Charters runs out of Cox Landing in Fort Lauderdale. From that
        home dock the 32 ft Contender reaches Gulf Stream water in under twenty minutes, with
        productive fishing grounds spanning roughly twenty-five miles in either direction along
        the Broward and southern Palm Beach coast. Most charters book pickups inside that radius,
        with Miami trips available on request for groups committed to a Biscayne Bay or Government
        Cut departure.
      </p>
      <p class="mt-5 font-body text-base leading-relaxed text-navy-950/75">
        Each service area below covers the inlets, marinas, neighborhoods, and fishable water that
        defines a trip from that side of the coast. We have been working this stretch of coastline
        for more than a decade and choose the run based on tide, wind, and where the bite is on
        that morning. Browse the area pages, then call {' '}
        <a href={`tel:+19545880578`} class="font-bold text-ocean-600 hover:underline">954-588-0578</a> to talk
        through pickup logistics.
      </p>
    </div>
  </section>

  <!-- Home dock featured banner -->
  <section class="pb-section-sm">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <a
        href={homeDockArea.href}
        class="group relative flex min-h-[18rem] overflow-hidden rounded-3xl bg-navy-950 shadow-lg transition-shadow hover:shadow-xl sm:min-h-[20rem]"
      >
        <img
          src={homeDockArea.heroImage}
          alt={homeDockArea.heroImageAlt}
          width="1200"
          height="600"
          loading="lazy"
          class="absolute inset-0 h-full w-full object-cover opacity-70 transition-transform duration-500 group-hover:scale-105"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/50 to-transparent"></div>
        <div class="relative mt-auto flex w-full flex-col p-8 sm:p-10">
          <span class="inline-flex w-fit items-center rounded-full bg-teal-500 px-3 py-1 font-body text-xs font-extrabold uppercase tracking-wide text-navy-950">
            Home Dock
          </span>
          <h2 class="mt-3 font-display text-2xl font-extrabold text-white sm:text-3xl">{homeDockArea.name}</h2>
          <p class="mt-2 max-w-lg font-body text-sm text-white/80 sm:text-base">
            Cox Landing sits a short idle from Port Everglades. From the slip, half-day offshore
            runs hit Gulf Stream water in under twenty minutes. Inshore charters work the
            Intracoastal toward Whiskey Creek and the New River.
          </p>
          <span class="mt-4 inline-flex items-center gap-1 font-body text-sm font-extrabold text-teal-400">
            View Fort Lauderdale Fishing Area
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- Other areas grid -->
  <section class="bg-sand-100 py-section-sm sm:py-section">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <span class="font-body text-sm font-bold uppercase tracking-wide text-teal-500">The Range</span>
        <h2 class="mt-2 font-display text-3xl font-extrabold text-navy-950 sm:text-4xl">
          Every Service Area We Cover
        </h2>
      </div>
      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          otherAreas.map((area) => (
            <a
              href={area.href}
              class="group relative flex min-h-[14rem] overflow-hidden rounded-2xl bg-navy-950 shadow-md transition-all hover:-translate-y-1 hover:shadow-xl"
            >
              <img
                src={area.heroImage}
                alt={area.heroImageAlt}
                width="500"
                height="380"
                loading="lazy"
                class="absolute inset-0 h-full w-full object-cover opacity-70 transition-transform duration-500 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/50 to-transparent" />
              <div class="relative mt-auto flex w-full flex-col p-6">
                <p class="font-body text-xs font-bold uppercase tracking-wide text-teal-400">{area.county}</p>
                <h3 class="mt-1 font-display text-xl font-extrabold uppercase text-white">{area.name}</h3>
                <p class="mt-2 font-body text-xs text-white/70">
                  {area.landmarks[0]} and {area.landmarks[1]} anchor the local fishing scene.
                </p>
                <span class="mt-3 inline-flex items-center gap-1 font-body text-xs font-extrabold text-teal-400">
                  View Area
                  <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <BookingCta
    heading="Outside Our Service Map?"
    body="Call Captain Jason. We pick up groups from neighborhoods across South Florida, and Miami trips are bookable with advance notice."
  />
</BaseLayout>
