---
export interface Props {
  question: string;
}

const { question } = Astro.props;
---

<details class="group/faq border-b border-navy-950/10 py-4">
  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-base font-bold text-navy-950">
    {question}
    <svg
      class="h-4 w-4 flex-shrink-0 text-ocean-600 transition-transform group-open/faq:rotate-180"
      viewBox="0 0 12 12"
      fill="none"
      aria-hidden="true"
    >
      <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  </summary>
  <div class="mt-3 font-body text-sm leading-relaxed text-navy-950/70">
    <slot />
  </div>
</details>
