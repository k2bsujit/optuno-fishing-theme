---
import { business } from '../data/site';
import { services, pricingNote, type Service } from '../data/services';
import FaqAccordion from './FaqAccordion.astro';
import CharterCard from './CharterCard.astro';
import BookingCta from './BookingCta.astro';

export interface Props {
  service: Service;
}

const { service } = Astro.props;
const otherServices = services.filter((s) => s.slug !== service.slug);
---

<!-- Hero -->
<section class="relative flex min-h-[60vh] items-end overflow-hidden bg-navy-950 text-white">
  <img
    src={service.heroImage}
    alt={service.heroImageAlt}
    width="1600"
    height="900"
    loading="eager"
    class="absolute inset-0 h-full w-full object-cover opacity-60"
  />
  <div class="absolute inset-0 bg-gradient-to-t from-navy-950 via-navy-950/50 to-navy-950/10"></div>

  <div class="relative mx-auto w-full max-w-7xl px-4 pb-16 pt-32 sm:px-6 sm:pb-20 lg:px-8">
    <nav aria-label="Breadcrumb" class="mb-4 flex items-center gap-1.5 font-body text-xs font-bold uppercase tracking-wide text-white/60">
      <a href="/" class="hover:text-teal-400">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/services/" class="hover:text-teal-400">Fishing Charters</a>
      <span aria-hidden="true">/</span>
      <span class="text-white/90">{service.title}</span>
    </nav>
    <span class="inline-flex w-fit items-center rounded-full bg-teal-500 px-3 py-1 font-body text-xs font-extrabold uppercase tracking-wide text-navy-950">
      {service.tag}
    </span>
    <h1 class="mt-4 max-w-2xl font-display text-4xl font-extrabold leading-tight sm:text-5xl">
      {service.h1}
    </h1>
    <p class="mt-4 max-w-xl font-body text-base text-white/85 sm:text-lg">
      {service.heroSubtitle}
    </p>
    <div class="mt-8 flex flex-wrap gap-4">
      <a
        href={service.itemBookingUrl}
        class="inline-flex items-center justify-center rounded-full bg-ocean-600 px-7 py-3.5 font-body text-sm font-bold text-white transition-colors hover:bg-ocean-500 sm:text-base"
      >
        {service.bookTripLabel}
      </a>
      <a
        href={business.phone.href}
        class="inline-flex items-center justify-center rounded-full border border-white/30 px-7 py-3.5 font-body text-sm font-bold text-white backdrop-blur transition-colors hover:bg-white/10 sm:text-base"
      >
        Call {business.phone.display}
      </a>
    </div>
  </div>
</section>

<!-- Intro -->
<section class="py-section-sm sm:py-section">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    {
      service.intro.map((paragraph, i) => (
        <>
          <p class="mt-5 font-body text-base leading-relaxed text-navy-950/75 first:mt-0">{paragraph}</p>
          {i === 1 && (
            <img
              src={service.secondaryImage.src}
              alt={service.secondaryImage.alt}
              width="1000"
              height="600"
              loading="lazy"
              class="my-8 aspect-video w-full rounded-2xl object-cover"
            />
          )}
        </>
      ))
    }
  </div>
</section>

<!-- Where we fish / why different -->
<section class="bg-sand-100 py-section-sm sm:py-section">
  <div class="mx-auto grid max-w-6xl grid-cols-1 items-center gap-10 px-4 sm:px-6 lg:grid-cols-2 lg:px-8">
    <img
      src={service.whyDifferent.image.src}
      alt={service.whyDifferent.image.alt}
      width="700"
      height="560"
      loading="lazy"
      class="aspect-[5/4] w-full rounded-2xl object-cover shadow-md"
    />
    <div>
      <span class="font-body text-sm font-bold uppercase tracking-wide text-teal-500">
        {service.whyDifferent.eyebrow}
      </span>
      <h2 class="mt-2 font-display text-3xl font-extrabold text-navy-950 sm:text-4xl">
        {service.whyDifferent.heading}
      </h2>
      <p class="mt-4 font-body text-base text-navy-950/70">{service.whyDifferent.body}</p>
    </div>
  </div>
</section>

<!-- Know before you book -->
<section class="py-section-sm sm:py-section">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <span class="font-body text-sm font-bold uppercase tracking-wide text-teal-500">
        {service.knowBeforeBook.eyebrow}
      </span>
      <h2 class="mt-2 font-display text-3xl font-extrabold text-navy-950 sm:text-4xl">
        {service.knowBeforeBook.heading}
      </h2>
    </div>
    <ul class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2">
      {
        service.knowBeforeBook.bullets.map((bullet) => (
          <li class="flex items-start gap-3 rounded-xl bg-sand-100 p-4">
            <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-teal-500" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7 7a1 1 0 0 1-1.4 0l-3-3a1 1 0 1 1 1.4-1.4l2.3 2.3 6.3-6.3a1 1 0 0 1 1.4 0Z" clip-rule="evenodd" />
            </svg>
            <span class="font-body text-sm text-navy-950/80">{bullet}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<!-- Day play-by-play -->
<section class="bg-navy-950 py-section-sm text-white sm:py-section">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:items-center">
      <div>
        <span class="font-body text-sm font-bold uppercase tracking-wide text-teal-400">
          {service.dayPlay.eyebrow}
        </span>
        <h2 class="mt-2 font-display text-3xl font-extrabold sm:text-4xl">{service.dayPlay.heading}</h2>
        <ol class="mt-8 space-y-6">
          {
            service.dayPlay.steps.map((step, i) => (
              <li class="flex gap-4">
                <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-teal-500 font-display text-sm font-extrabold text-navy-950">
                  {i + 1}
                </span>
                <div>
                  <h3 class="font-display text-base font-extrabold">{step.title}</h3>
                  <p class="mt-1 font-body text-sm text-white/70">{step.body}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
      <img
        src={service.dayPlay.image.src}
        alt={service.dayPlay.image.alt}
        width="700"
        height="860"
        loading="lazy"
        class="aspect-[4/5] w-full rounded-2xl object-cover"
      />
    </div>
  </div>
</section>

<!-- Why choose us -->
<section class="py-section-sm sm:py-section">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="rounded-3xl bg-sand-100 p-8 sm:p-12">
      <span class="font-body text-sm font-bold uppercase tracking-wide text-teal-500">
        {service.whyChoose.eyebrow}
      </span>
      <h2 class="mt-2 font-display text-3xl font-extrabold text-navy-950 sm:text-4xl">
        {service.whyChoose.heading}
      </h2>
      <ul class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
        {
          service.whyChoose.bullets.map((bullet) => (
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-ocean-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7 7a1 1 0 0 1-1.4 0l-3-3a1 1 0 1 1 1.4-1.4l2.3 2.3 6.3-6.3a1 1 0 0 1 1.4 0Z" clip-rule="evenodd" />
              </svg>
              <span class="font-body text-sm font-bold text-navy-950/80">{bullet}</span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<!-- Pricing -->
<section class="bg-sand-100 pb-section-sm sm:pb-section">
  <div class="mx-auto max-w-2xl px-4 text-center sm:px-6 lg:px-8">
    <span class="font-body text-sm font-bold uppercase tracking-wide text-teal-500">Trip Pricing</span>
    <h2 class="mt-2 font-display text-2xl font-extrabold text-navy-950 sm:text-3xl">Call for Current Rates</h2>
    <p class="mt-4 font-body text-sm text-navy-950/70">{pricingNote}</p>
    <div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href={business.phone.href}
        class="inline-flex w-full items-center justify-center rounded-full bg-navy-950 px-6 py-3 font-body text-sm font-bold text-white transition-colors hover:bg-navy-900 sm:w-auto"
      >
        Call {business.phone.display} for a Quote
      </a>
      <a
        href={service.itemBookingUrl}
        class="inline-flex w-full items-center justify-center rounded-full bg-ocean-600 px-6 py-3 font-body text-sm font-bold text-white transition-colors hover:bg-ocean-500 sm:w-auto"
      >
        Request a Date Online
      </a>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="py-section-sm sm:py-section">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center font-display text-3xl font-extrabold text-navy-950 sm:text-4xl">
      {service.tag} Questions, Answered
    </h2>
    <p class="mt-2 text-center font-body text-sm text-navy-950/60">
      Real questions from real anglers booking the Cool Runnings boat.
    </p>
    <div class="mt-8 rounded-2xl bg-sand-100 p-2 sm:p-4">
      {
        service.faqs.map((faq) => (
          <FaqAccordion question={faq.question}>{faq.answer}</FaqAccordion>
        ))
      }
    </div>
  </div>
</section>

<!-- Cross-links -->
<section class="bg-sand-100 py-section-sm sm:py-section">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <h2 class="text-center font-display text-3xl font-extrabold text-navy-950 sm:text-4xl">
      More Ways to Fish With Captain Jason
    </h2>
    <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        otherServices.map((other) => (
          <CharterCard
            href={other.href}
            tag={other.tag}
            title={other.title}
            description={other.cardDescription}
            image={other.heroImage}
            imageAlt={other.heroImageAlt}
          />
        ))
      }
    </div>
  </div>
</section>

<BookingCta
  heading={`Book Your ${service.tag} Trip`}
  body="Two to four guests, all gear and bait covered, catch cleaned at the dock. Captain Jason confirms your dock time the night before."
  bookingUrl={service.itemBookingUrl}
  backgroundImage={service.heroImage}
/>
