---
export interface Props {
  name: string;
  tripType: string;
  quote: string;
}

const { name, tripType, quote } = Astro.props;
---

<figure class="snap-card flex h-full w-[85%] flex-shrink-0 flex-col rounded-2xl bg-white/5 p-6 backdrop-blur sm:w-[360px]">
  <div class="flex gap-0.5 text-teal-400" aria-hidden="true">
    {Array.from({ length: 5 }).map(() => (
      <svg viewBox="0 0 20 20" class="h-4 w-4 fill-current">
        <path d="M10 1.5l2.6 5.5 6 .7-4.4 4.1 1.2 6-5.4-3-5.4 3 1.2-6L1.4 7.7l6-.7L10 1.5Z" />
      </svg>
    ))}
  </div>
  <blockquote class="mt-3 flex-1 font-body text-sm text-white/85">"{quote}"</blockquote>
  <figcaption class="mt-4 font-body text-sm">
    <span class="font-extrabold text-white">{name}</span>
    <span class="text-white/50"> · {tripType}</span>
  </figcaption>
</figure>
