---
import { business } from '../data/site';
---

<div
  class="fixed inset-x-0 bottom-0 z-40 flex border-t border-white/10 bg-navy-950/95 backdrop-blur lg:hidden"
  style="padding-bottom: env(safe-area-inset-bottom, 0px);"
>
  <a
    href={business.phone.href}
    class="flex flex-1 items-center justify-center gap-2 py-3 font-body text-sm font-bold text-white"
  >
    <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" aria-hidden="true">
      <path
        d="M2 3.5c0-.8.7-1.5 1.5-1.5H5l1.2 3.4-1.1 1.1a8 8 0 0 0 4.9 4.9l1.1-1.1L14.5 11v1.5c0 .8-.7 1.5-1.5 1.5C6.7 14 2 9.3 2 3.5Z"
        stroke="currentColor"
        stroke-width="1.3"
        stroke-linejoin="round"
      />
    </svg>
    Call
  </a>
  <a
    href={business.bookingUrl}
    class="flex flex-1 items-center justify-center gap-2 bg-ocean-600 py-3 font-body text-sm font-bold text-white"
  >
    Book A Charter
  </a>
</div>
