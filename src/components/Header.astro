---
import { business, nav, assets } from '../data/site';
import MobileMenu from './MobileMenu.astro';

// Only render nav items (and child links) enabled for the current milestone.
// Milestone B flips the `enabled` flags in src/data/site.ts — no changes needed here.
const visibleNav = nav
  .map((item) => ({
    ...item,
    children: item.children?.filter((child) => child.enabled),
  }))
  .filter((item) => item.enabled || (item.children && item.children.length > 0));
---

<header class="sticky top-0 z-50 w-full">
  <!-- Announcement bar -->
  <div class="bg-teal-500 py-2 text-center text-sm font-medium text-navy-950">
    <a href={business.bookingUrl} class="hover:underline">
      Half-Day to Full-Day Charters · Book Now!
    </a>
  </div>

  <!-- Main nav row -->
  <div class="bg-navy-900 text-white shadow-md">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
      <a href="/" class="flex items-center gap-2" aria-label={`${business.name} — home`}>
        <img
          src={assets.logo}
          alt={business.name}
          width="180"
          height="48"
          class="h-10 w-auto sm:h-12"
        />
      </a>

      <!-- Desktop nav -->
      <nav aria-label="Primary" class="hidden lg:flex lg:items-center lg:gap-1">
        {
          visibleNav.map((item) => (
            <div class="group relative">
              {item.children && item.children.length > 0 ? (
                <>
                  <button
                    type="button"
                    class="flex items-center gap-1 rounded-md px-3 py-2 font-body text-sm font-bold text-white transition-colors hover:text-teal-400 focus-visible:text-teal-400"
                    aria-haspopup="true"
                    aria-expanded="false"
                    data-mega-trigger
                  >
                    {item.label}
                    <svg
                      class="h-3 w-3 transition-transform"
                      viewBox="0 0 12 12"
                      fill="none"
                      aria-hidden="true"
                      data-mega-chevron
                    >
                      <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    </svg>
                  </button>
                  <div
                    class="invisible absolute left-1/2 top-full z-40 w-64 -translate-x-1/2 rounded-lg border border-white/10 bg-navy-900 p-2 opacity-0 shadow-xl transition-all duration-150 group-hover:visible group-hover:opacity-100"
                    data-mega-panel
                  >
                    {item.children.map((child) => (
                      <a
                        href={child.href}
                        class="block rounded-md px-3 py-2 font-body text-sm text-white/90 transition-colors hover:bg-navy-800 hover:text-teal-400"
                      >
                        {child.label}
                      </a>
                    ))}
                  </div>
                </>
              ) : (
                <a
                  href={item.href}
                  class="block rounded-md px-3 py-2 font-body text-sm font-bold text-white transition-colors hover:text-teal-400 focus-visible:text-teal-400"
                >
                  {item.label}
                </a>
              )}
            </div>
          ))
        }
      </nav>

      <!-- Desktop contact/CTA -->
      <div class="hidden items-center gap-4 lg:flex">
        <a
          href={business.phone.href}
          class="font-body text-sm font-bold text-white transition-colors hover:text-teal-400"
        >
          {business.phone.display}
        </a>
        <a
          href={business.bookingUrl}
          class="inline-flex items-center justify-center rounded-md bg-ocean-600 px-4 py-2 font-body text-sm font-bold text-white transition-colors hover:bg-ocean-500"
        >
          Book A Charter
        </a>
      </div>

      <!-- Mobile menu toggle -->
      <button
        type="button"
        id="mobile-menu-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 text-white lg:hidden"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Open main menu"
      >
        <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M4 6h16M4 12h16M4 18h16"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
          />
        </svg>
      </button>
    </div>
  </div>

  <MobileMenu nav={visibleNav} />
</header>

<script>
  // Mega-dropdown: click-to-toggle for keyboard/touch users, in addition to
  // the CSS :hover reveal used by mouse users.
  const triggers = document.querySelectorAll<HTMLButtonElement>('[data-mega-trigger]');

  function openPanel(group: Element) {
    const panel = group.querySelector('[data-mega-panel]');
    const chevron = group.querySelector('[data-mega-chevron]');
    const trigger = group.querySelector('[data-mega-trigger]');
    panel?.classList.remove('invisible', 'opacity-0');
    panel?.classList.add('visible', 'opacity-100');
    chevron?.classList.add('rotate-180');
    trigger?.setAttribute('aria-expanded', 'true');
    group.setAttribute('data-open', '');
  }

  function closePanel(group: Element) {
    const panel = group.querySelector('[data-mega-panel]');
    const chevron = group.querySelector('[data-mega-chevron]');
    const trigger = group.querySelector('[data-mega-trigger]');
    panel?.classList.add('invisible', 'opacity-0');
    panel?.classList.remove('visible', 'opacity-100');
    chevron?.classList.remove('rotate-180');
    trigger?.setAttribute('aria-expanded', 'false');
    group.removeAttribute('data-open');
  }

  function closeAllPanels() {
    document.querySelectorAll('.group[data-open]').forEach(closePanel);
  }

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const group = trigger.closest('.group');
      if (!group) return;
      const isOpen = group.hasAttribute('data-open');
      closeAllPanels();
      if (!isOpen) openPanel(group);
    });
  });

  document.addEventListener('click', (event) => {
    if (!(event.target instanceof Node)) return;
    document.querySelectorAll('.group[data-open]').forEach((openGroup) => {
      if (!openGroup.contains(event.target as Node)) closePanel(openGroup);
    });
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeAllPanels();
  });

  // Mobile menu toggle
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  menuToggle?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    menuToggle.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
  });
</script>
