---
import { business } from '../data/site';
import type { NavChild } from '../data/site';

export interface Props {
  nav: Array<{
    label: string;
    href: string;
    enabled: boolean;
    children?: NavChild[];
  }>;
}

const { nav } = Astro.props;
---

<div id="mobile-menu" class="hidden border-t border-white/10 bg-navy-900 text-white lg:hidden">
  <nav aria-label="Mobile" class="mx-auto max-w-7xl divide-y divide-white/10 px-4 sm:px-6">
    {
      nav.map((item, index) => (
        <div class="py-1">
          {item.children && item.children.length > 0 ? (
            <details class="group/accordion">
              <summary class="flex cursor-pointer list-none items-center justify-between rounded-md px-2 py-3 font-body text-base font-bold text-white">
                {item.label}
                <svg
                  class="h-4 w-4 transition-transform group-open/accordion:rotate-180"
                  viewBox="0 0 12 12"
                  fill="none"
                  aria-hidden="true"
                >
                  <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                </svg>
              </summary>
              <div class="flex flex-col gap-1 pb-2 pl-4">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="rounded-md px-2 py-2 font-body text-sm text-white/80 hover:text-teal-400"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </details>
          ) : (
            <a
              href={item.href}
              class="block rounded-md px-2 py-3 font-body text-base font-bold text-white hover:text-teal-400"
            >
              {item.label}
            </a>
          )}
        </div>
      ))
    }
  </nav>

  <div class="flex flex-col gap-3 border-t border-white/10 px-4 py-4 sm:px-6">
    <a
      href={business.phone.href}
      class="text-center font-body text-base font-bold text-white hover:text-teal-400"
    >
      {business.phone.display}
    </a>
    <a
      href={business.bookingUrl}
      class="inline-flex items-center justify-center rounded-md bg-ocean-600 px-4 py-3 font-body text-base font-bold text-white transition-colors hover:bg-ocean-500"
    >
      Book A Charter
    </a>
  </div>
</div>
